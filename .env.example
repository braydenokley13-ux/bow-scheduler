# ─────────────────────────────────────────────────────────────────────────────
# BOW Story Scheduler — environment variables
# Copy this file to .env.local and fill in the values you need.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend mode ──────────────────────────────────────────────────────────────
# "mock"   — in-memory mock store, no external dependencies (default for local dev)
# "google" — live Google Sheets + Calendar backend
BOOKING_BACKEND_MODE=mock

# ── Public URL ─────────────────────────────────────────────────────────────────
# Used to build absolute URLs in emails and management links.
# In Vercel this is set automatically via VERCEL_URL; override if needed.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Admin auth ────────────────────────────────────────────────────────────────
# Password for the admin login screen.
# Default in non-production: "preview-access" (see lib/env.ts)
ADMIN_PASSWORD=change-me-before-deploy

# Secret used to sign admin session JWTs and management tokens.
# Must be at least 16 chars. Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-before-deploy

# Separate secret used specifically for management tokens (reschedule / cancel links).
# If omitted, AUTH_SECRET is reused. Separate secrets give independent revocation.
MANAGEMENT_TOKEN_SECRET=

# ── Google Sheets ──────────────────────────────────────────────────────────────
# Service account credentials for reading/writing the spreadsheet.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# ── Google Calendar ────────────────────────────────────────────────────────────
# Calendar ID where interview events are created.
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# If you want Google Meet links, impersonate a Workspace user that has meet.
GOOGLE_WORKSPACE_IMPERSONATED_USER=staff@your-domain.com

# ── Upstash Redis (booking locks) ─────────────────────────────────────────────
# Required when BOOKING_BACKEND_MODE=google to prevent double-bookings.
# Get these from upstash.com or from the Vercel KV integration.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── Transactional email (Resend) ──────────────────────────────────────────────
# If omitted, emails are written to .mock/emails/*.json instead of being sent.
RESEND_API_KEY=re_your_key
EMAIL_FROM=BOW Sports Capital <no-reply@your-domain.com>
EMAIL_REPLY_TO=bow@your-domain.com
